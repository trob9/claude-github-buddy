# GitHub Buddy Server Configuration
# Copy this file to .env and uncomment only what you want to override.
# EVERYTHING IS OPTIONAL — the tool works out-of-the-box with no .env at all.

# --- Ports (almost never need changing) ---
# Defaults already MATCH the Chrome extension: HTTP 47382, WS 47383.
# Only change these if those ports clash with something else on your machine —
# and if you do, you must also update the ports hardcoded in the extension.
# HTTP_PORT=47382
# WS_PORT=47383

# --- Node.js binary (only the daemon launchers use this) ---
# Leave unset to use whatever `node` is on your PATH.
#   macOS (Homebrew Apple Silicon): /opt/homebrew/bin/node
#   macOS (Homebrew Intel):         /usr/local/bin/node
#   Windows:                        C:\Program Files\nodejs\node.exe
# NODE_PATH=/opt/homebrew/bin/node

# --- Directories ---
# Where your git repos are cloned/found. Default: <home>/Projects.
#   macOS/Linux: /Users/you/Projects     Windows: C:\Users\you\Projects
# PROJECTS_DIR=/Users/you/Projects
# Where question/action markdown files are stored. Default: "<repo>/questions and actions".
# PR_REVIEWS_DIR=/Users/you/Projects/claude-github-buddy/questions and actions

# --- How Claude runs ("native Claude setup") — set this in the extension's
#     Settings UI instead; these env vars only force/override it ---
# CLAUDE_RUN_MODE=interactive    # interactive | print | sdk | vertex
# CLAUDE_SKIP_PERMISSIONS=1      # start Claude with --dangerously-skip-permissions
# ANTHROPIC_API_KEY=sk-ant-...   # only for runMode=sdk
# CLAUDE_CODE_USE_VERTEX=1       # only for runMode=vertex (+ project/region)

# --- Git protocol for github.com: "https" (default) or "ssh" ---
# HTTPS works out-of-the-box on Windows (Git Credential Manager) and anywhere
# `gh auth login` has run. Use "ssh" only if you have SSH keys set up.
# GIT_GITHUB_PROTOCOL=https
# GIT_GITHUB_SSH_KEY=~/.ssh/id_ed25519
