# GitHub Buddy Server Configuration
# Copy this file to .env and update with your settings.
# Every value has a sensible cross-platform default, so .env is optional —
# only set what you want to override.

# Node.js binary path (only needed by the daemon launchers).
# Leave unset to use whatever `node` is on your PATH.
#   macOS (Homebrew Apple Silicon): /opt/homebrew/bin/node
#   macOS (Homebrew Intel):         /usr/local/bin/node
#   Windows:                        C:\Program Files\nodejs\node.exe
# NODE_PATH=/opt/homebrew/bin/node

# Server ports
HTTP_PORT=13030
WS_PORT=13031

# Projects directory (where your git repos are cloned/found).
# Default: <your home folder>/Projects on every OS.
#   macOS/Linux: /Users/yourusername/Projects
#   Windows:     C:\Users\yourusername\Projects
# PROJECTS_DIR=C:\Users\yourusername\Projects

# PR reviews directory (where question/action markdown files are stored).
# Default: "<repo>/questions and actions".
#   Windows example: C:\Users\yourusername\Projects\claude-github-buddy\questions and actions
# PR_REVIEWS_DIR=C:\Users\yourusername\Projects\claude-github-buddy\questions and actions

# Git protocol for github.com: "https" (default) or "ssh".
# HTTPS works out-of-the-box on Windows (Git Credential Manager) and anywhere
# `gh auth login` has run. Use "ssh" only if you have SSH keys set up.
# GIT_GITHUB_PROTOCOL=https
# GIT_GITHUB_SSH_KEY=~/.ssh/id_ed25519
